# ──────────────────────────────────────────────
# iCore Agent Platform — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME="iCore Agent Platform"
APP_VERSION="0.1.0"
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8080

# ── LiteLLM 模型配置 ──────────────────────────
# Strands 通过 LiteLLM 对接任意模型，格式: provider/model-name
# 填入你实际使用的模型 + 对应 API Key 即可，无需 AWS

# 主力模型（协调器 + 子 Agent）
MODEL_ID=anthropic/claude-sonnet-4-5
# 快速模型（可选，暂未使用，留作扩展）
MODEL_ID_FAST=anthropic/claude-haiku-3-20250307

# ── 各 Provider 的 API Key（按需填写其中一项）──
# Anthropic 直连
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...
# MODEL_ID=openai/gpt-4o

# Google Gemini
# GEMINI_API_KEY=...
# MODEL_ID=gemini/gemini-2.0-flash

# Z.AI / 智谱 GLM 模型（使用 zai/* 模型时填）
# ZAI_API_KEY=...
# MODEL_ID=zai/glm-4.7

# 本地 Ollama（无需 Key）
# MODEL_ID=ollama/llama3.3

# ── Strands Orchestrator ──────────────────────
AGENT_MAX_TOKENS=8192
AGENT_TEMPERATURE=0.1

# ── Sequential Agent (mini-SWE-agent style) ───
# 留空 = 自动使用 MODEL_ID；或单独指定
SEQUENTIAL_MODEL=
SEQUENTIAL_MAX_STEPS=30
SEQUENTIAL_TIMEOUT_PER_STEP=60
# Working directory inside the container / local runner
SEQUENTIAL_WORKSPACE=/tmp/icore-seq-workspace

# ── Conversation Memory (Redis) ───────────────
REDIS_URL=redis://localhost:6379/0
MEMORY_TTL_SECONDS=86400

# ── Auth (optional: validate tokens via iCore ft-base) ───
ICORE_BASE_URL=http://localhost:9001
ICORE_SECRET=change-me

# ── Tools config ─────────────────────────────
# Tavily for web search (https://app.tavily.com)
TAVILY_API_KEY=your-tavily-api-key

# Max depth for file operations
FILE_OPS_MAX_SIZE_MB=10
